// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "ensure-wandas",
			"type": "shell",
			"command": "if [ ! -d .venv ]; then python3 -m venv .venv; fi && ./.venv/bin/pip install -r requirements.txt",
			"problemMatcher": [],
			"presentation": {
				"reveal": "silent"
			}
		},
		{
			"type": "npm",
			"script": "watch",
			"problemMatcher": "$ts-webpack-watch",
			"isBackground": true,
			"dependsOn": [
				"ensure-wandas"
			],
			"presentation": {
				"reveal": "never",
				"group": "watchers"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"type": "npm",
			"script": "watch-tests",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never",
				"group": "watchers"
			},
			"group": "build"
		},
		{
			"type": "npm",
			"script": "compile",
			"problemMatcher": "$tsc",
			"group": "build"
		},
		{
			"label": "tasks: watch-tests",
			"dependsOn": [
				"ensure-wandas",
				"npm: watch",
				"npm: watch-tests"
			],
			"problemMatcher": []
		}
	]
}