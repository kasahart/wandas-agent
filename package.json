{
  "name": "wandas-agent",
  "displayName": "wandas-agent",
  "description": "Wandas Copilot Integration",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onCommand:wandas.showVersion",
    "onCommand:wandas.createPythonFile",
    "onChatParticipant:wandas.hello"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "wandas.showVersion",
        "title": "Show Version"
      },
      {
        "command": "wandas.createPythonFile",
        "title": "Create Python File"
      }
    ],
    "chatParticipants": [
      {
        "id": "wandas.hello",
        "name": "wandas",
        "description": "Expert AI assistant for Wandas library",
        "isSticky": true
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "xvfb-run -a vscode-test",
    "test:ui": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "glob": "^10.4.5",
    "mocha": "^10.8.2"
  }
}